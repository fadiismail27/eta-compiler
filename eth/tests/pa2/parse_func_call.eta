test() {
    // procedure call (no return)
    print("hello")

    // call in expression
    x: int = foo(1, 2)
    y: int = bar()

    // nested calls
    z: int = foo(bar(), 3)

    // call with complex args
    w: int = foo(1 + 2, x * y)
}

foo(a: int, b: int): int { return a + b }
bar(): int { return 0 }
print(s: int[]) { }
