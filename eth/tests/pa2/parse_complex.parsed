(((use io))
 ((gcd
   ((a int) (b int))
   (int)
   ((while (!= a 0) ((if (< a b) (= b (- b a)) (= a (- a b))))) (return b)))
  (sort
   ((a ([] int)))
   ()
   ((= (i int) 0)
    (= (n int) (length a))
    (while
     (< i n)
     ((= (j int) i)
      (while
       (> j 0)
       ((if
         (> ([] a (- j 1)) ([] a j))
         ((= (swap int) ([] a j))
          (= ([] a j) ([] a (- j 1)))
          (= ([] a (- j 1)) swap)))
        (= j (- j 1))))
      (= i (+ i 1))))))
  (main
   ((args ([] ([] int))))
   ()
   ((= (x int) (gcd 12 8)) (= (a ([] int)) (3 1 2)) (sort a)))))